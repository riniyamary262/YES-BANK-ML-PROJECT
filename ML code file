# 1. Convert date to datetime
from datetime import datetime

def convert_date(date_str):
    month, year = date_str.split('-')
    month_num = datetime.strptime(month, '%b').month
    full_year = 2000 + int(year)
    return datetime(full_year, month_num, 1)

ml_data['Date'] = ml_data['Date'].apply(convert_date)

# 2. Extract year and month
ml_data['Year'] = ml_data['Date'].dt.year
ml_data['Month'] = ml_data['Date'].dt.month
ml_data['Month_Name'] = ml_data['Date'].dt.strftime('%b')

# 3. Sort by date
ml_data = ml_data.sort_values('Date').reset_index(drop=True)

print("Date converted successfully!")
print("Year and Month extracted!")
print("Data sorted by date!")

# 4. Create derived features
ml_data['Daily_Return'] = ml_data['Close'].pct_change() * 100
ml_data['Volatility'] = ml_data['Daily_Return'].rolling(window=6).std()
ml_data['Price_Range'] = ml_data['High'] - ml_data['Low']
ml_data['Gap'] = ml_data['Open'] - ml_data['Close'].shift(1)

# 5. Create lag features
for lag in [1, 2, 3, 6, 12]:
    ml_data[f'Close_Lag_{lag}'] = ml_data['Close'].shift(lag)
    ml_data[f'Open_Lag_{lag}'] = ml_data['Open'].shift(lag)
    ml_data[f'High_Lag_{lag}'] = ml_data['High'].shift(lag)
    ml_data[f'Low_Lag_{lag}'] = ml_data['Low'].shift(lag)

# 6. Create moving averages
for window in [3, 6, 12]:
    ml_data[f'Close_MA_{window}'] = ml_data['Close'].rolling(window=window).mean()
    ml_data[f'Close_Std_{window}'] = ml_data['Close'].rolling(window=window).std()
    ml_data[f'Close_Min_{window}'] = ml_data['Close'].rolling(window=window).min()
    ml_data[f'Close_Max_{window}'] = ml_data['Close'].rolling(window=window).max()

# 7. Create price ratios
ml_data['Open_Close_Ratio'] = ml_data['Open'] / ml_data['Close']
ml_data['High_Low_Ratio'] = ml_data['High'] / ml_data['Low']

# Remove rows with NaN values (from lag and rolling calculations)
ml_data = ml_data.dropna()

