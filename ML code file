from sklearn.model_selection import cross_val_score
from sklearn.linear_model import LinearRegression
from sklearn.ensemble import RandomForestRegressor
from scipy import stats
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt

print("="*60)
print("HYPOTHESIS TEST 3: Model Performance Comparison")
print("="*60)

# Prepare data
X = ml_data[['Open', 'High', 'Low', 'Close_Lag_1', 'MA_3']]
y = ml_data['Close']

# Cross-validation for both models
cv_folds = 10

# Linear Regression
lr_model = LinearRegression()
lr_scores = cross_val_score(lr_model, X, y, cv=cv_folds, scoring='r2')

# Random Forest
rf_model = RandomForestRegressor(n_estimators=50, random_state=42)
rf_scores = cross_val_score(rf_model, X, y, cv=cv_folds, scoring='r2')

print(f"\n CROSS-VALIDATION RESULTS ({cv_folds}-fold):")
print("\nLinear Regression Scores:")
print(f"  Individual: {[f'{s:.3f}' for s in lr_scores]}")
print(f"  Mean R²: {lr_scores.mean():.4f}")
print(f"  Std Dev: {lr_scores.std():.4f}")

print("\nRandom Forest Scores:")
print(f"  Individual: {[f'{s:.3f}' for s in rf_scores]}")
print(f"  Mean R²: {rf_scores.mean():.4f}")
print(f"  Std Dev: {rf_scores.std():.4f}")

# Perform paired t-test (scores are paired by fold)
t_stat, p_value = stats.ttest_rel(lr_scores, rf_scores)

print(f"\n STATISTICAL TEST RESULTS:")
print(f"T-Statistic: {t_stat:.4f}")
print(f"P-Value: {p_value:.6f}")
print(f"Mean Difference (RF - LR): {rf_scores.mean() - lr_scores.mean():.4f}")

# Visualize
plt.figure(figsize=(15, 5))

plt.subplot(1, 3, 1)
models = ['Linear Regression', 'Random Forest']
mean_scores = [lr_scores.mean(), rf_scores.mean()]
std_scores = [lr_scores.std(), rf_scores.std()]
bars = plt.bar(models, mean_scores, yerr=std_scores, capsize=5, 
               color=['#3498db', '#2ecc71'], edgecolor='black')
plt.ylabel('R² Score')
plt.title('Model Performance Comparison', fontsize=12, fontweight='bold')
