from scipy import stats
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

# Prepare data
current_price = ml_data['Close']
previous_price = ml_data['Close_Lag_1']

# Remove any NaN values
test_data = pd.DataFrame({
    'Previous': previous_price,
    'Current': current_price
}).dropna()

# Calculate correlation
correlation, p_value = stats.pearsonr(test_data['Previous'], test_data['Current'])

print("="*60)
print("HYPOTHESIS TEST 1: Previous Price vs Current Price")
print("="*60)

print(f"\n SAMPLE SIZE: {len(test_data)} observations")
print(f"\n TEST RESULTS:")
print(f"Correlation Coefficient (r): {correlation:.4f}")
print(f"P-Value: {p_value:.10f}")

# Visualize
plt.figure(figsize=(12, 5))

plt.subplot(1, 2, 1)
plt.scatter(test_data['Previous'], test_data['Current'], alpha=0.5, color='teal')
plt.xlabel('Previous Month Price (₹)')
plt.ylabel('Current Month Price (₹)')
plt.title('Scatter Plot: Previous vs Current Price', fontsize=12, fontweight='bold')
plt.grid(True, alpha=0.3)

# Add regression line
z = np.polyfit(test_data['Previous'], test_data['Current'], 1)
p = np.poly1d(z)
plt.plot(test_data['Previous'], p(test_data['Previous']), "r--", linewidth=2)

plt.subplot(1, 2, 2)
residuals = test_data['Current'] - p(test_data['Previous'])
plt.hist(residuals, bins=20, edgecolor='black', alpha=0.7, color='skyblue')
plt.axvline(x=0, color='red', linestyle='--')
plt.xlabel('Residuals (₹)')
plt.ylabel('Frequency')
plt.title('Residual Distribution', fontsize=12, fontweight='bold')
plt.grid(True, alpha=0.3)

plt.tight_layout()
plt.show()

# Decision
alpha = 0.05
print("\n" + "="*60)
print("HYPOTHESIS TESTING DECISION")
print("="*60)
print(f"Significance Level (α): {alpha}")

if p_value < alpha:
    print("\n REJECT NULL HYPOTHESIS (H₀)")
    print("There IS a significant relationship between previous and current prices.")
    print(f"Correlation is {correlation:.4f} with p-value = {p_value:.10f}")
else:
    print("\n FAIL TO REJECT NULL HYPOTHESIS (H₀)")
    print("There is NO significant relationship between previous and current prices.")


# ============================================
# HYPOTHESIS TEST 2: Volatility vs Returns
# ============================================
from scipy import stats

print("="*60)
print("HYPOTHESIS TEST 2: Volatility vs Returns")
print("="*60)

# Split data into high and low volatility groups
median_volatility = ml_data['Volatility'].median()
low_volatility = ml_data[ml_data['Volatility'] <= median_volatility]['Return'].dropna()
high_volatility = ml_data[ml_data['Volatility'] > median_volatility]['Return'].dropna()

print(f"\n📊 DATA SUMMARY:")
print(f"Low Volatility Group: {len(low_volatility)} samples")
print(f"  - Mean Return: {low_volatility.mean():.2f}%")
print(f"  - Std Dev: {low_volatility.std():.2f}%")
print(f"\nHigh Volatility Group: {len(high_volatility)} samples")
print(f"  - Mean Return: {high_volatility.mean():.2f}%")
print(f"  - Std Dev: {high_volatility.std():.2f}%")

# Perform Levene's test for equal variances
levene_stat, levene_p = stats.levene(low_volatility, high_volatility)
print(f"\n Levene's Test (Equal Variance):")
print(f"  Levene Statistic: {levene_stat:.4f}")
print(f"  P-Value: {levene_p:.4f}")

# Perform t-test (independent samples)
if levene_p > 0.05:
    # Equal variances assumed
    t_stat, p_value = stats.ttest_ind(low_volatility, high_volatility, equal_var=True)
    print("\n Using t-test with EQUAL variances assumption")
else:
    # Equal variances not assumed (Welch's t-test)
    t_stat, p_value = stats.ttest_ind(low_volatility, high_volatility, equal_var=False)
    print("\n Using Welch's t-test with UNEQUAL variances assumption")

print(f"\n TEST RESULTS:")
print(f"T-Statistic: {t_stat:.4f}")
print(f"P-Value: {p_value:.6f}")

# Visualize
plt.figure(figsize=(12, 5))

